{
    "open spotlight search": "cmd + space",
    "open launchpad": "f4",
    "open notification center": "cmd + option + a",
    "open system settings": "cmd + ,",
    "open finder": "cmd + option + space",
    "show or hide desktop": "cmd + f3",
    "lock the computer": "cmd + ctrl + q",
    "switch between open apps": "cmd + tab",
    "switch between apps backwards": "cmd + shift + tab",
    "open mission control": "ctrl + up arrow",
    "show app windows": "ctrl + down arrow",
    "snap window to left side": "ctrl + cmd + left arrow",
    "snap window to right side": "ctrl + cmd + right arrow",
    "maximize window": "ctrl + cmd + f",
    "minimize window": "cmd + m",
    "move window to another space": "ctrl + cmd + arrow keys",
    "open new finder window": "cmd + n",
    "close finder window": "cmd + w",
    "create new folder": "cmd + shift + n",
    "go back in finder": "cmd + [",
    "go forward in finder": "cmd + ]",
    "go up one folder level": "cmd + up arrow",
    "rename selected item": "enter",
    "refresh window": "cmd + r",
    "focus address bar": "cmd + l",
    "select all text": "cmd + a",
    "copy selected item": "cmd + c",
    "cut selected item": "cmd + x",
    "paste copied item": "cmd + v",
    "undo last action": "cmd + z",
    "redo last action": "cmd + shift + z",
    "save current file": "cmd + s",
    "print current file": "cmd + p",
    "find text": "cmd + f",
    "find and replace text": "cmd + option + f",
    "delete previous word": "option + delete",
    "delete next word": "fn + option + delete",
    "select text using arrow keys": "shift + arrow keys",
    "move cursor by word": "option + arrow keys",
    "create new virtual desktop": "ctrl + cmd + d",
    "switch to desktop on the left": "ctrl + left arrow",
    "switch to desktop on the right": "ctrl + right arrow",
    "close current virtual desktop": "ctrl + option + cmd + w",
    "copy full screen to clipboard": "cmd + shift + ctrl + 3",
    "copy selected area to clipboard": "cmd + shift + ctrl + 4",
    "save screenshot of full screen": "cmd + shift + 3",
    "save screenshot of selected area": "cmd + shift + 4",
    "open screenshot toolbar": "cmd + shift + 5",
    "open emoji and symbol picker": "cmd + ctrl + space",
    "change input language or keyboard": "ctrl + space",
    "open activity monitor": "cmd + space then type activity monitor",
    "force quit active app": "cmd + option + esc",
    "close active app": "cmd + q",
    "new tab": "cmd + t",
    "close tab": "cmd + w",
    "select tab": "cmd + number",
    "show dock apps": "ctrl + f3",
    "save as": "cmd + shift + s"
}
